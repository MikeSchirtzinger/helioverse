{
  "name": "helioverse",
  "version": "0.1.0",
  "private": true,
  "description": "Helioverse — Aurora Forecasting on a Live 3D Heliosphere",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "contracts:validate": "uv run contracts/tests/validate.py",
    "contracts:vectors": "uv run contracts/tests/gen_vectors.py",
    "check:types": "corepack pnpm -r run check:types",
    "check:lint": "corepack pnpm -r run check:lint",
    "check:test": "corepack pnpm -r run check:test",
    "check:all": "corepack pnpm contracts:validate && corepack pnpm check:types && corepack pnpm check:lint && corepack pnpm check:test",
    "dev:web": "corepack pnpm --filter @helioverse/web dev",
    "build:web": "corepack pnpm --filter @helioverse/web build",
    "rust:build": "cd crates/helio-core && cargo build",
    "rust:test": "cd crates/helio-core && cargo test",
    "rust:wasm": "cd crates/helio-core && wasm-pack build --target web",
    "setup": "echo 'Run: pnpm install && cd crates/helio-core && cargo build'"
  }
}
