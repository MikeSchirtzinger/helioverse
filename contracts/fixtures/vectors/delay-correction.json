{
  "schema_version": "1.0.0",
  "vectors": [
    {
      "function": "l1_delay_seconds",
      "tolerance": {
        "type": "relative",
        "value": 1e-09
      },
      "cases": [
        {
          "name": "typical_quiet_400",
          "inputs": {
            "spacecraft_earth_distance_km": 1500000.0,
            "measured_speed_kms": 400.0
          },
          "expect": {
            "delay_s": 3750.0
          }
        },
        {
          "name": "storm_800_noaa_assumption",
          "inputs": {
            "spacecraft_earth_distance_km": 1500000.0,
            "measured_speed_kms": 800.0
          },
          "expect": {
            "delay_s": 1875.0
          }
        },
        {
          "name": "quiet_fixture_match",
          "inputs": {
            "spacecraft_earth_distance_km": 1480000.0,
            "measured_speed_kms": 380.0
          },
          "expect": {
            "delay_s": 3894.7368421052633
          }
        },
        {
          "name": "fast_storm_fixture_match",
          "inputs": {
            "spacecraft_earth_distance_km": 1520000.0,
            "measured_speed_kms": 720.0
          },
          "expect": {
            "delay_s": 2111.1111111111113
          }
        },
        {
          "name": "slow_wind_320",
          "inputs": {
            "spacecraft_earth_distance_km": 1610000.0,
            "measured_speed_kms": 320.0
          },
          "expect": {
            "delay_s": 5031.25
          }
        },
        {
          "name": "speed_too_low_err",
          "inputs": {
            "spacecraft_earth_distance_km": 1500000.0,
            "measured_speed_kms": 150.0
          },
          "expect": {
            "error": "OutOfRange"
          }
        },
        {
          "name": "speed_too_high_err",
          "inputs": {
            "spacecraft_earth_distance_km": 1500000.0,
            "measured_speed_kms": 3200.0
          },
          "expect": {
            "error": "OutOfRange"
          }
        },
        {
          "name": "distance_out_of_range_err",
          "inputs": {
            "spacecraft_earth_distance_km": 1000000.0,
            "measured_speed_kms": 400.0
          },
          "expect": {
            "error": "OutOfRange"
          }
        }
      ]
    }
  ]
}
