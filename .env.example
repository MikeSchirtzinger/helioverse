# Helioverse — Environment Variables (placeholders only — no secrets)
#
# Copy this to .env and fill in values for local development.
# .env is git-ignored and must NEVER be committed.

# --- Cloudflare / R2 (W1-P1, W1-P4, W1-P7, W1-P9) ---
# Required for live deployment; not required for local fixture tests.
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=
# R2_PUBLIC_BUCKET=helioverse-public
# R2_PUBLIC_DOMAIN=

# --- NASA / DONKI API key (W1-P1d) ---
# Required for live DONKI pull; not required for local fixture tests.
# NASA_API_KEY=

# --- Web Push VAPID (W1-P7) ---
# Required for live push delivery; not required for local fixture tests.
# VAPID_SUBJECT=mailto:alerts@helioverse.example
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# --- Open-Meteo (W1-P5, go-look engine) ---
# Open-Meteo is free and keyless for non-commercial use.
# No key needed.

# --- Helioviewer ---
# Public API, no key needed.
