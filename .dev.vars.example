# Helioverse — Cloudflare Workers .dev.vars (placeholders only — no secrets)
#
# Copy this to .dev.vars and fill in values for local wrangler dev.
# .dev.vars is git-ignored and must NEVER be committed.
#
# Each worker (ingest, imagery, alerts, backfill) can have its own
# .dev.vars; this is a shared template.

# CLOUDFLARE_ACCOUNT_ID=
# R2_PUBLIC_BUCKET=helioverse-public
# NASA_API_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_PUBLIC_KEY=
